10 ' RIVER.BAS - River Raid clone for GW-BASIC
20 ' Homage to my first programming language. - Kiran
30 ' Controls: arrows steer, space fires.
40 ' Ctrl+Break to stop, type LIST to read this source.
50 SCREEN 1: COLOR 0,1: KEY OFF: CLS: RANDOMIZE TIMER
60 DIM LB(199), RB(199)
70 DIM EX(15), EY(15), ET(15), EA(15)
80 DIM BX(7), BY(7), BA(7)
90 DIM DX(5), DY(5), DA(5)
100 GOTO 200
110 ' --- Reset state ---
120 PX = 160: PY = 170: SC = 0: FU = 100: LV = 3
130 RC = 160: RW = 80
140 FOR I = 0 TO 199: LB(I) = RC - RW/2: RB(I) = RC + RW/2: NEXT I
150 FOR I = 0 TO 15: EA(I) = 0: NEXT I
160 FOR I = 0 TO 7:  BA(I) = 0: NEXT I
170 FOR I = 0 TO 5:  DA(I) = 0: NEXT I
180 LS = 0: FR = 0: GO = 0: DS = 0
190 RETURN
200 ' --- Title screen ---
210 GOSUB 110
220 CLS
230 LOCATE 4, 11: PRINT "RIVER RAID"
240 LOCATE 6, 9:  PRINT "GW-BASIC, 1992"
250 LOCATE 10, 6: PRINT "ARROWS  =  STEER"
260 LOCATE 11, 6: PRINT "SPACE   =  FIRE"
270 LOCATE 13, 4: PRINT "PRESS ANY KEY TO FLY"
280 LOCATE 18, 2: PRINT "PRESS Q THEN LIST"
290 LOCATE 19, 2: PRINT "TO READ THE SOURCE"
300 K$ = INPUT$(1)
310 CLS
320 ' --- Main loop ---
330 GOSUB 1000
340 GOSUB 2000
350 GOSUB 3000
360 GOSUB 4000
370 GOSUB 5000
380 GOSUB 6000
390 CLS
400 GOSUB 7000
410 GOSUB 8000
420 FU = FU - .15
430 IF FU <= 0 THEN GOSUB 9500: GOTO 480
440 FR = FR + 1
450 ' Speed governor: short pause for steadiness
460 FOR Z = 1 TO 40: NEXT Z
480 IF GO = 1 THEN GOTO 11000
490 GOTO 330
1000 ' --- Input ---
1010 K$ = INKEY$
1020 IF K$ = "" THEN RETURN
1030 IF K$ = CHR$(0) + CHR$(75) THEN PX = PX - 5
1040 IF K$ = CHR$(0) + CHR$(77) THEN PX = PX + 5
1050 IF K$ = " " THEN GOSUB 1100
1055 IF K$ = "q" OR K$ = "Q" THEN STOP
1060 RETURN
1100 ' Fire bullet
1110 FOR I = 0 TO 7
1120   IF BA(I) = 0 THEN BX(I) = PX: BY(I) = PY - 6: BA(I) = 1: SOUND 900, 1: I = 7: GOTO 1140
1130 NEXT I
1140 RETURN
2000 ' --- Scroll river ---
2010 FOR I = 199 TO 1 STEP -1
2020   LB(I) = LB(I-1)
2030   RB(I) = RB(I-1)
2040 NEXT I
2050 RC = RC + (RND - .5) * 6
2060 IF RC < 60  THEN RC = 60
2070 IF RC > 260 THEN RC = 260
2080 RW = RW + (RND - .5) * 4
2090 IF RW < 50  THEN RW = 50
2100 IF RW > 110 THEN RW = 110
2110 LB(0) = RC - RW/2
2120 RB(0) = RC + RW/2
2130 RETURN
3000 ' --- Spawn + move enemies ---
3010 IF FR - LS < 22 THEN GOTO 3100
3020 FOR I = 0 TO 15
3030   IF EA(I) = 0 THEN GOTO 3050
3040 NEXT I: GOTO 3100
3050 ET(I) = INT(RND * 3)
3060 EX(I) = LB(0) + 8 + RND * (RB(0) - LB(0) - 16)
3070 EY(I) = 0: EA(I) = 1
3080 LS = FR
3100 FOR I = 0 TO 15
3110   IF EA(I) = 0 THEN GOTO 3160
3120   IF ET(I) = 2 THEN EY(I) = EY(I) + 3.2 ELSE EY(I) = EY(I) + 1.6
3130   IF ET(I) = 0 THEN EX(I) = EX(I) + SIN(FR/8 + I) * 1.2
3140   IF EY(I) > 195 THEN EA(I) = 0
3160 NEXT I
3170 RETURN
4000 ' --- Bullets ---
4010 FOR I = 0 TO 7
4020   IF BA(I) = 0 THEN GOTO 4050
4030   BY(I) = BY(I) - 7
4040   IF BY(I) < 8 THEN BA(I) = 0
4050 NEXT I
4060 RETURN
5000 ' --- Fuel depots ---
5010 IF FR - DS < 320 THEN GOTO 5070
5020 FOR I = 0 TO 5
5030   IF DA(I) = 0 THEN GOTO 5050
5040 NEXT I: GOTO 5070
5050 DX(I) = LB(0) + (RB(0) - LB(0)) / 2
5060 DY(I) = 0: DA(I) = 1: DS = FR
5070 FOR I = 0 TO 5
5080   IF DA(I) = 0 THEN GOTO 5110
5090   DY(I) = DY(I) + 1.6
5100   IF DY(I) > 195 THEN DA(I) = 0
5110 NEXT I
5120 RETURN
6000 ' --- Collisions ---
6010 PR = INT(PY)
6020 IF PR < 0   THEN PR = 0
6030 IF PR > 199 THEN PR = 199
6040 IF PX < LB(PR) + 4 OR PX > RB(PR) - 4 THEN GOSUB 9500: RETURN
6050 FOR I = 0 TO 15
6060   IF EA(I) = 0 THEN GOTO 6090
6070   IF ABS(PX - EX(I)) < 7 AND ABS(PY - EY(I)) < 7 THEN GOSUB 9500: RETURN
6090 NEXT I
6100 FOR I = 0 TO 5
6110   IF DA(I) = 0 THEN GOTO 6140
6120   IF ABS(PX - DX(I)) < 10 AND ABS(PY - DY(I)) < 6 THEN FU = 100: SC = SC + 80: SOUND 1300, 2: DA(I) = 0
6140 NEXT I
6150 FOR I = 0 TO 7
6160   IF BA(I) = 0 THEN GOTO 6260
6170   FOR J = 0 TO 15
6180     IF EA(J) = 0 THEN GOTO 6240
6190     IF ABS(BX(I) - EX(J)) < 7 AND ABS(BY(I) - EY(J)) < 7 THEN BA(I) = 0: EA(J) = 0: SC = SC + (10 + ET(J) * 10): SOUND 250, 1: J = 15: GOTO 6260
6240   NEXT J
6260 NEXT I
6270 RETURN
7000 ' --- Draw ---
7010 ' River banks (color 1)
7020 FOR I = 8 TO 191 STEP 2
7030   LINE (0, I)-(LB(I), I+1), 1, BF
7040   LINE (RB(I), I)-(319, I+1), 1, BF
7050 NEXT I
7060 ' Fuel depots (color 2 magenta with center pip)
7070 FOR I = 0 TO 5
7080   IF DA(I) = 0 THEN GOTO 7100
7090   LINE (DX(I)-7, DY(I)-4)-(DX(I)+7, DY(I)+4), 2, BF: PSET (DX(I), DY(I)), 3
7100 NEXT I
7110 ' Enemies
7120 FOR I = 0 TO 15
7130   IF EA(I) = 0 THEN GOTO 7180
7140   IF ET(I) = 0 THEN GOSUB 7300
7150   IF ET(I) = 1 THEN GOSUB 7400
7160   IF ET(I) = 2 THEN GOSUB 7500
7180 NEXT I
7190 ' Bullets
7200 FOR I = 0 TO 7
7210   IF BA(I) = 0 THEN GOTO 7230
7220   LINE (BX(I), BY(I))-(BX(I), BY(I)+3), 3
7230 NEXT I
7240 ' Player plane
7250 GOSUB 7600
7260 RETURN
7300 ' Helicopter
7310 LINE (EX(I)-6, EY(I)-1)-(EX(I)+6, EY(I)+2), 3, BF
7320 LINE (EX(I)-1, EY(I)-3)-(EX(I)+1, EY(I)-1), 3, BF
7330 PSET (EX(I)-9, EY(I)), 3: PSET (EX(I)+9, EY(I)), 3
7340 RETURN
7400 ' Ship
7410 LINE (EX(I)-9, EY(I))-(EX(I)+9, EY(I)+3), 3, BF
7420 LINE (EX(I)-1, EY(I)-4)-(EX(I)+1, EY(I)), 3, BF
7430 RETURN
7500 ' Jet
7510 LINE (EX(I)-1, EY(I)-5)-(EX(I)+1, EY(I)+5), 2, BF
7520 LINE (EX(I)-6, EY(I))-(EX(I)+6, EY(I)+1), 2, BF
7530 RETURN
7600 ' Player plane (color 3 white)
7610 LINE (PX, PY-6)-(PX, PY+5), 3
7620 LINE (PX-6, PY)-(PX+6, PY), 3
7630 LINE (PX-3, PY+3)-(PX+3, PY+3), 3
7640 PSET (PX-1, PY-5), 3: PSET (PX+1, PY-5), 3
7650 RETURN
8000 ' --- HUD ---
8010 LOCATE 1, 1:  PRINT "SCORE"; SC;
8020 LOCATE 1, 14: PRINT "FUEL"; INT(FU);
8030 LOCATE 1, 26: PRINT "LIVES"; LV;
8040 RETURN
9500 ' --- Crash ---
9510 SOUND 120, 6: SOUND 90, 6
9520 LV = LV - 1
9530 IF LV <= 0 THEN GO = 1: RETURN
9540 PX = (LB(170) + RB(170)) / 2: PY = 170
9550 FU = FU + 30: IF FU > 100 THEN FU = 100
9560 RETURN
11000 ' --- Game over ---
11010 CLS
11020 LOCATE 7, 11: PRINT "GAME OVER"
11030 LOCATE 9, 9:  PRINT "FINAL SCORE"
11040 LOCATE 10, 13: PRINT SC
11050 LOCATE 14, 4: PRINT "PRESS ANY KEY"
11060 LOCATE 15, 7: PRINT "TO RESTART"
11070 K$ = INPUT$(1)
11080 GOTO 200

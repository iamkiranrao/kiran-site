<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sparkline Preview</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0a0a0a;
            --text-primary: #f0e6d3;
            --text-secondary: #f0e6d3;
            --text-muted: #5a5347;
            --border: #222222;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 2rem;
        }
        .hero-title-area {
            text-align: center;
            padding: 2rem 2rem 1.5rem;
        }
        .subpage-hero-title {
            font-size: 3.5rem;
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 1.1;
            margin-bottom: 0.5rem;
        }
        .subpage-hero-subtitle {
            font-size: 1.05rem;
            font-weight: 400;
            color: var(--text-muted);
        }
        .sparkline-container {
            width: 100%;
            max-width: 1000px;
            padding: 1rem 2rem 2rem;
        }
        .wf-sparkline-svg {
            width: 100%;
            height: auto;
            display: block;
        }
        .sparkline-path {
            stroke-dasharray: 2000;
            stroke-dashoffset: 2000;
            animation: drawLine 2s ease-out 0.3s forwards;
        }
        @keyframes drawLine {
            to { stroke-dashoffset: 0; }
        }
        .sparkline-node {
            opacity: 0;
            animation: fadeNode 0.4s ease-out forwards;
        }
        @keyframes fadeNode {
            to { opacity: 1; }
        }
        .sparkline-node-circle {
            transition: r 0.2s ease;
            cursor: pointer;
        }
        .sparkline-node:hover .sparkline-node-circle { r: 8; }
        .sparkline-node:hover .sparkline-label-company { fill: var(--text-primary); }
        .sparkline-label-company {
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            font-size: 11px;
            fill: var(--text-secondary);
            transition: fill 0.2s ease;
        }
        .sparkline-label-year {
            font-family: 'Inter', sans-serif;
            font-weight: 400;
            font-size: 10px;
            fill: var(--text-muted);
        }
        .sparkline-label-role {
            font-family: 'Inter', sans-serif;
            font-weight: 400;
            font-size: 9px;
            fill: var(--text-muted);
        }
        .sparkline-pulse {
            animation: sparkPulse 2s ease-in-out infinite;
        }
        @keyframes sparkPulse {
            0%, 100% { opacity: 0.4; r: 12; }
            50% { opacity: 0; r: 20; }
        }
        .border-line {
            width: 100%;
            max-width: 1000px;
            height: 1px;
            background: var(--border);
        }
    </style>
</head>
<body>
    <a href="#main-content" class="skip-link" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Skip to main content</a>
    
    <div class="hero-title-area">
        <h1 class="subpage-hero-title">Career Highlights</h1>
        <p class="subpage-hero-subtitle">Real products. Real outcomes. Real scale.</p>
    </div>

    <div class="sparkline-container">
        <svg class="wf-sparkline-svg" viewBox="0 0 900 200" preserveAspectRatio="xMidYMid meet" aria-label="Career timeline from 2008 to present">

            <line x1="60" y1="160" x2="860" y2="160" stroke="var(--border)" stroke-width="0.5" opacity="0.5"/>
            <line x1="60" y1="120" x2="860" y2="120" stroke="var(--border)" stroke-width="0.5" opacity="0.3"/>
            <line x1="60" y1="80" x2="860" y2="80" stroke="var(--border)" stroke-width="0.5" opacity="0.2"/>

            <path class="sparkline-path"
                  d="M 100,150 C 180,148 220,140 280,135 C 340,130 380,110 440,100 C 500,90 560,65 620,55 C 680,45 720,40 780,30"
                  fill="none"
                  stroke="var(--text-primary)"
                  stroke-width="2"
                  stroke-linecap="round"
                  opacity="0.4"/>

            <path d="M 100,150 C 180,148 220,140 280,135 C 340,130 380,110 440,100 C 500,90 560,65 620,55 C 680,45 720,40 780,30 L 780,160 L 100,160 Z"
                  fill="url(#sparkFill)"
                  opacity="0.08"/>

            <defs>
                <linearGradient id="sparkFill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--text-primary)"/>
                    <stop offset="100%" stop-color="var(--text-primary)" stop-opacity="0"/>
                </linearGradient>
            </defs>

            <g class="sparkline-node" style="animation-delay: 0.5s;">
                <circle class="sparkline-node-circle" cx="100" cy="150" r="5" fill="var(--bg-primary)" stroke="var(--text-muted)" stroke-width="2"/>
                <text class="sparkline-label-year" x="100" y="175" text-anchor="middle">Pre-2008</text>
                <text class="sparkline-label-company" x="100" y="140" text-anchor="middle" dy="-12">Early Career</text>
            </g>

            <g class="sparkline-node" style="animation-delay: 0.8s;">
                <circle class="sparkline-node-circle" cx="230" cy="138" r="5" fill="var(--bg-primary)" stroke="var(--text-primary)" stroke-width="2"/>
                <text class="sparkline-label-company" x="230" y="128" text-anchor="middle" dy="-12">Magley</text>
                <text class="sparkline-label-year" x="230" y="175" text-anchor="middle">2008</text>
                <text class="sparkline-label-role" x="230" y="185" text-anchor="middle">Sr. Consultant</text>
            </g>

            <g class="sparkline-node" style="animation-delay: 1.1s;">
                <circle class="sparkline-node-circle" cx="380" cy="105" r="6" fill="var(--bg-primary)" stroke="var(--text-primary)" stroke-width="2"/>
                <text class="sparkline-label-company" x="380" y="95" text-anchor="middle" dy="-12">Wells Fargo</text>
                <text class="sparkline-label-year" x="380" y="175" text-anchor="middle">2012</text>
                <text class="sparkline-label-role" x="380" y="185" text-anchor="middle">AVP, Product</text>
            </g>

            <g class="sparkline-node" style="animation-delay: 1.4s;">
                <circle class="sparkline-node-circle" cx="530" cy="68" r="6" fill="var(--bg-primary)" stroke="var(--text-primary)" stroke-width="2"/>
                <text class="sparkline-label-company" x="530" y="58" text-anchor="middle" dy="-12">First Republic</text>
                <text class="sparkline-label-year" x="530" y="175" text-anchor="middle">2016</text>
                <text class="sparkline-label-role" x="530" y="185" text-anchor="middle">Director, PM</text>
            </g>

            <g class="sparkline-node" style="animation-delay: 1.7s;">
                <circle class="sparkline-node-circle" cx="680" cy="42" r="6" fill="var(--bg-primary)" stroke="var(--text-primary)" stroke-width="2"/>
                <text class="sparkline-label-company" x="680" y="32" text-anchor="middle" dy="-12">Wells Fargo</text>
                <text class="sparkline-label-year" x="680" y="175" text-anchor="middle">2023</text>
                <text class="sparkline-label-role" x="680" y="185" text-anchor="middle">VP, Mobile & AI</text>
            </g>

            <g class="sparkline-node" style="animation-delay: 2.0s;">
                <circle class="sparkline-pulse" cx="780" cy="30" r="12" fill="none" stroke="var(--text-primary)" stroke-width="1.5"/>
                <circle class="sparkline-node-circle" cx="780" cy="30" r="7" fill="var(--text-primary)" stroke="var(--text-primary)" stroke-width="2"/>
                <text class="sparkline-label-company" x="780" y="20" text-anchor="middle" dy="-12" style="fill: var(--text-primary); font-weight: 700;">Avatour AI</text>
                <text class="sparkline-label-year" x="780" y="175" text-anchor="middle">2025</text>
                <text class="sparkline-label-role" x="780" y="185" text-anchor="middle">VP of Product</text>
            </g>

            <g opacity="0.15" stroke="var(--text-muted)" stroke-width="1" stroke-dasharray="3,3">
                <line x1="100" y1="155" x2="100" y2="165"/>
                <line x1="230" y1="143" x2="230" y2="165"/>
                <line x1="380" y1="111" x2="380" y2="165"/>
                <line x1="530" y1="74" x2="530" y2="165"/>
                <line x1="680" y1="48" x2="680" y2="165"/>
                <line x1="780" y1="37" x2="780" y2="165"/>
            </g>
        </svg>
    </div>
    <div class="border-line"></div>
</body>
</html>
